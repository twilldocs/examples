# Your Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Your Twill Docs API key (starts with twdc_) — get one at https://www.twilldocs.com/
TWILL_API_KEY=twdc_...

# Twill Docs API base URL.
#   Production: https://api.twilldocs.com
#   Local dev:  http://localhost:8080
TWILL_BASE_URL=https://api.twilldocs.com

# Optional — the Claude model used to extract structured invoice data.
# Sonnet is the sweet spot of quality vs. cost for this kind of extraction.
ANTHROPIC_MODEL=claude-sonnet-5
