# Your Twill Docs API key (starts with twdc_) — get one at https://www.twilldocs.com/
TWILL_API_KEY=twdc_...

# Twill Docs API base URL.
#   Production: https://api.twilldocs.com
#   Local dev:  http://localhost:8080
TWILL_BASE_URL=https://api.twilldocs.com

# Your business details — the "seller" printed on every receipt.
# These come from your config, NOT from the incoming webhook.
MERCHANT_NAME=Northwind Studio
MERCHANT_ADDRESS=500 Market St, San Francisco, CA
MERCHANT_TAX_ID=
MERCHANT_EMAIL=billing@northwind.example

# Optional: shared secret used to verify incoming webhook signatures (HMAC-SHA256).
# If set, requests must carry a valid X-Signature header or they're rejected.
# Leave blank to skip verification (fine for local testing only).
WEBHOOK_SIGNING_SECRET=

# Port for this example server.
PORT=3000
