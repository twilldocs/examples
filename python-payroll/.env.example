# Your Twill Docs API key (starts with twdc_) — get one at https://www.twilldocs.com/
TWILL_API_KEY=twdc_...

# Twill Docs API base URL.
#   Production: https://api.twilldocs.com
#   Local dev:  http://localhost:8080
TWILL_BASE_URL=https://api.twilldocs.com

# The employer printed on every payslip — from your config, not the CSV.
EMPLOYER_NAME=Northwind Studio
EMPLOYER_ADDRESS=500 Market St, San Francisco, CA
EMPLOYER_EMAIL=payroll@northwind.example

# Optional: 3-letter currency for the run (default USD).
PAYROLL_CURRENCY=USD
